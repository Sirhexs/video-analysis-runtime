# Video Analysis Runtime
PORT=18765
HOST=127.0.0.1
RUNTIME_PROFILE=cloud
# RUNTIME_AUTH_TOKEN=change-me
# AUTH_DISABLED=0
# DATA_DIR=
# LOG_DIR=
# ALLOWED_ORIGINS=http://localhost:3000,chrome-extension://extension-id
# MAX_CONCURRENT_JOBS=1
# JOB_RETENTION_MS=86400000
# ASSET_RETENTION_MS=86400000
# MAX_ASSET_BYTES=2147483648
# ASSET_IMPORT_TIMEOUT_MS=180000
# IDLE_EXIT_MS=0

# Cloud ASR default
ASR_PROVIDER=dashscope
DASHSCOPE_API_KEY=
DASHSCOPE_ASR_MODEL=qwen3-asr-flash
# WHISPER_BASE_URL=https://api.openai.com/v1
# WHISPER_API_KEY=
# WHISPER_MODEL=whisper-1

# Local ASR (hybrid profiles)
# LOCAL_ASR_MODEL=small
# LOCAL_ASR_MODEL_PATH=
# LOCAL_ASR_DEVICE=cuda
# LOCAL_ASR_COMPUTE_TYPE=float16
# LOCAL_ASR_LANGUAGE=zh
# LOCAL_ASR_FALLBACK=dashscope

# Server-side LLM providerRef=default
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Douyin connector profile only
# DOUYIN_COOKIE=
# DOWNLOAD_TIMEOUT_MS=180000
# DOWNLOAD_RETRIES=3

# Media runtime
# FFMPEG_PATH=
# FFPROBE_PATH=
# VIDEO_ANALYSIS_RUNTIME_INSTALL_DIR=
# VIDEO_ANALYSIS_RUNTIME_FFMPEG_DIR=
# VIDEO_ANALYSIS_RUNTIME_ASR_DIR=
# VIDEO_ANALYSIS_RUNTIME_ASR_RUNNER=
